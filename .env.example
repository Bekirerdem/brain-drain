# =============================================================================
# Brain Drain — Environment Variables
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` — it is in .gitignore.

# -----------------------------------------------------------------------------
# Solana Network
# -----------------------------------------------------------------------------
# Use "devnet" for development, "mainnet-beta" for production demo
SOLANA_NETWORK=devnet

# Helius RPC endpoint (replace YOUR_HELIUS_KEY with the key from https://helius.dev)
# Devnet:   https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# Mainnet:  https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
HELIUS_API_KEY=YOUR_HELIUS_KEY

# -----------------------------------------------------------------------------
# Coinbase Developer Platform (CDP) — Buyer-side MPC wallets
# https://portal.cdp.coinbase.com
# -----------------------------------------------------------------------------
# Step 1: Create a "Secret API Key" in the CDP portal (Ed25519 algorithm).
#         Download the JSON. It contains:
#           - "id"          -> CDP_API_KEY_ID
#           - "privateKey"  -> CDP_API_KEY_SECRET (single base64 line, no PEM wrapper)
# Step 2: Create a "Wallet Secret" in the same portal page (separate button).
#         This is required to sign on-chain transactions.
#           - copy the secret -> CDP_WALLET_SECRET
CDP_API_KEY_ID=YOUR_KEY_ID_UUID
CDP_API_KEY_SECRET=YOUR_ED25519_PRIVATE_KEY_BASE64
CDP_WALLET_SECRET=YOUR_WALLET_SECRET

# -----------------------------------------------------------------------------
# Google Gemini — Agent reasoning + RAG embeddings (PRIMARY)
# Get an API key from a Google Cloud project (Generative Language API enabled)
# or from https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
# Reasoning model:  gemini-3.1-pro-preview (default — frontier-class with thinking_level)
#                   gemini-3.1-pro-preview-customtools (Vertex AI only — agent-optimized)
# Fallback:         gemini-2.5-flash (cheap, fast — used for trivial queries)
# Embedding model:  gemini-embedding-001
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Default reasoning model. Override per-call where useful.
# NOTE: gemini-3-pro-preview was deprecated 2026-03; use gemini-3.1-pro-preview.
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# -----------------------------------------------------------------------------
# Anthropic Claude — OPTIONAL multi-model demo (Day 7+ stretch)
# https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
# Only needed if we showcase "agent pays different LLMs via x402" in the demo.
# Default model: claude-haiku-4-5-20251001 (cheapest reasoning at $1/M input).
# Leave commented out if not using.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Seller (Bekir) — Where x402 payouts settle
# -----------------------------------------------------------------------------
# Your mainnet Phantom Solana address (where USDC lands as Phantom Cash)
# For devnet testing, use your devnet address
SELLER_SOLANA_ADDRESS=YOUR_PHANTOM_ADDRESS

# Optional: Phantom Tag (handle) for friendlier seller display
SELLER_PHANTOM_TAG=@l3eksS

# -----------------------------------------------------------------------------
# x402 Pricing Configuration
# -----------------------------------------------------------------------------
# Default price per snippet query, in USDC (e.g., 0.05 = 5 cents)
X402_DEFAULT_PRICE_USDC=0.05

# USDC mint addresses (do not change unless using testnet USDC variant)
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
