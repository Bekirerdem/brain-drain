# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# session transcripts and grant prep artifacts (uploaded to Drive, not committed)
claude-session.jsonl
codex-session.jsonl
git-log.txt

# private vault content (anything Bekir does not want to ship publicly)
seed-vault/private/

# RAG index cache (rebuildable from seed-vault/)
.cache/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
